{
    "name": "filamentphp/advanced-import",
    "description": "Advanced Excel import functionality for Filament resources with preview, batch processing, and audit trail",
    "keywords": [
        "laravel",
        "filament",
        "import",
        "excel",
        "filament-plugin"
    ],
    "homepage": "https://github.com/anselmocossa/filamentphp-advanced-import",
    "license": "MIT",
    "authors": [
        {
            "name": "Anselmo Kossa",
            "email": "anselmocossa@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0|^5.0",
        "maatwebsite/excel": "^3.1|^4.0",
        "spatie/laravel-package-tools": "^1.9"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Filament\\AdvancedImport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Filament\\AdvancedImport\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Filament\\AdvancedImport\\AdvancedImportServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
